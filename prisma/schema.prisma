model PhrasebookCategory {
  id          String                 @id @default(uuid())
  emoji       String
  name        String
  sortOrder   Int                    @default(0)
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt
  phrases     PhrasebookPhrase[]
  suggestions PhrasebookSuggestion[]

  @@map("phrasebook_category")
}

model PhrasebookPhrase {
  id              String                    @id @default(uuid())
  categoryId      String
  original        String
  transliteration String?
  translation     String
  lang            Language
  sortOrder       Int                       @default(0)
  createdAt       DateTime                  @default(now())
  updatedAt       DateTime                  @updatedAt
  category        PhrasebookCategory        @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  examples        PhrasebookPhraseExample[]
  words           PhrasebookPhraseWord[]
  saves           UserPhrasebookSave[]

  @@index([categoryId])
  @@index([lang])
  @@map("phrasebook_phrase")
}

model PhrasebookPhraseWord {
  id          String           @id @default(uuid())
  phraseId    String
  original    String
  translation String
  position    Int              @default(0)
  phrase      PhrasebookPhrase @relation(fields: [phraseId], references: [id], onDelete: Cascade)

  @@index([phraseId])
  @@map("phrasebook_phrase_word")
}

model PhrasebookPhraseExample {
  id               String           @id @default(uuid())
  phraseId         String
  phrase           String
  translation      String
  context          String?
  phrasebookPhrase PhrasebookPhrase @relation(fields: [phraseId], references: [id], onDelete: Cascade)

  @@index([phraseId])
  @@map("phrasebook_phrase_example")
}

model PhrasebookSuggestion {
  id          String              @id @default(uuid())
  userId      String?
  original    String
  translation String
  lang        Language
  context     String?
  categoryId  String?
  createdAt   DateTime            @default(now())
  category    PhrasebookCategory? @relation(fields: [categoryId], references: [id])
  user        User?               @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("phrasebook_suggestion")
}

model UserPhrasebookSave {
  id        String           @id @default(cuid())
  userId    String
  phraseId  String
  createdAt DateTime         @default(now())
  phrase    PhrasebookPhrase @relation(fields: [phraseId], references: [id], onDelete: Cascade)
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, phraseId])
  @@index([userId])
  @@map("user_phrasebook_save")
}

model TextPhrase {
  id          String                 @id @default(uuid())
  original    String
  normalized  String
  translation String
  language    Language
  notes       String?
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt
  occurrences TextPhraseOccurrence[]

  @@unique([normalized, language])
  @@index([language])
  @@map("text_phrase")
}

model TextPhraseOccurrence {
  id                 String     @id @default(uuid())
  phraseId           String
  textId             String
  pageNumber         Int
  startTokenPosition Int
  endTokenPosition   Int
  createdAt          DateTime   @default(now())
  phrase             TextPhrase @relation(fields: [phraseId], references: [id], onDelete: Cascade)
  text               Text       @relation(fields: [textId], references: [id], onDelete: Cascade)

  @@unique([phraseId, textId, pageNumber, startTokenPosition])
  @@index([textId, pageNumber])
  @@index([phraseId])
  @@map("text_phrase_occurrence")
}

model FeedbackThread {
  id                String               @id @default(uuid())
  ticketNumber      Int                  @unique @default(autoincrement())
  userId            String
  type              FeedbackType
  status            FeedbackStatus       @default(NEW)
  priority          FeedbackPriority     @default(MEDIUM)
  title             String?
  assigneeAdminId   String?
  assignedByAdminId String?
  assignedAt        DateTime?
  contextType       FeedbackContextType?
  contextWord       String?
  contextSentence   String?
  contextLemmaId    String?
  contextTextId     String?
  contextPosition   Int?
  contextAction     String?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  closedAt          DateTime?
  messages          FeedbackMessage[]
  assignedByAdmin   User?                @relation("FeedbackThreadAssignedBy", fields: [assignedByAdminId], references: [id])
  assigneeAdmin     User?                @relation("FeedbackThreadAssignee", fields: [assigneeAdminId], references: [id])
  lemma             Lemma?               @relation("LemmaFeedbackThreads", fields: [contextLemmaId], references: [id])
  text              Text?                @relation("TextFeedbackThreads", fields: [contextTextId], references: [id])
  user              User                 @relation("UserFeedbackThreads", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([type])
  @@index([priority])
  @@index([assigneeAdminId])
  @@index([createdAt])
  @@index([updatedAt])
  @@map("feedback_thread")
}

model FeedbackMessage {
  id            String              @id @default(uuid())
  threadId      String
  authorType    FeedbackAuthorType
  messageType   FeedbackMessageType @default(PUBLIC_REPLY)
  authorId      String
  body          String
  isReadByUser  Boolean             @default(false)
  isReadByAdmin Boolean             @default(false)
  createdAt     DateTime            @default(now())
  thread        FeedbackThread      @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@index([threadId])
  @@index([threadId, isReadByAdmin])
  @@index([threadId, isReadByUser])
  @@map("feedback_message")
}

model FeedbackReaction {
  id        String       @id @default(uuid())
  userId    String
  type      ReactionType
