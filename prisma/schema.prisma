// State machine:
//   DRAFT      → PENDING     via POST /:id/submit (owner)
//   PENDING    → APPROVED    via POST /:id/review decision=approve (admin)
//   PENDING    → REJECTED    via POST /:id/review decision=reject  (admin)
//   REJECTED   → PENDING     via POST /:id/submit again; clears reviewComment/reviewedBy/reviewedAt
//   APPROVED   → (terminal)  no transitions out
// Editable states (PATCH/DELETE by owner): DRAFT, REJECTED
// Submittable states (POST /:id/submit by owner): DRAFT, REJECTED
model TextSubmission {
  id              String                 @id @default(uuid())
  userId          String
  title           String
  language        String
  author          String?
  sourceUrl       String?
  content         String?                @db.Text
  comment         String?
  status          TextSubmissionStatus   @default(PENDING)
  submissionType  SubmissionType         @default(EXTERNAL)
  licenseType     SubmissionLicenseType?
  publicationYear Int?
  contentRich     Json?
  reviewedBy      String?
  reviewedAt      DateTime?
  reviewComment   String?
  textId          String?
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt

  user       User                   @relation("TextSubmissionAuthor", fields: [userId], references: [id], onDelete: Cascade)
  reviewer   User?                  @relation("TextSubmissionReviewer", fields: [reviewedBy], references: [id], onDelete: SetNull)
  pages      TextSubmissionPage[]

  @@index([userId])
  @@index([status])
  @@index([userId, status])
  @@map("text_submission")
}

model TextSubmissionPage {
  id           String         @id @default(cuid())
  submissionId String
  pageNumber   Int
  title        String?
  contentRich  Json

  submission   TextSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@unique([submissionId, pageNumber])
  @@index([submissionId, pageNumber])
  @@map("text_submission_page")
}

model TrackingEvent {
  id        BigInt  @id @default(autoincrement())
  visitorId String
  sessionId String
  userId    String?

  eventType String
  path      String?
  referrer  String?
  device    String?
  browser   String?
  os        String?
  country   String?
  city      String?
  metadata  Json?

  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([visitorId, createdAt])
  @@index([eventType, createdAt])
  @@index([path, createdAt])
  @@index([eventType, createdAt, path])
  @@map("tracking_event")
}

model TrackingDailyStats {
  date             DateTime @id
  uniqueVisitors   Int
  sessions         Int
  pageviews        Int
  totalEvents      Int
  avgSessionSec    Int
  bounceRate       Float
  topPaths         Json
  topReferrers     Json
  topCountries     Json
  topCities        Json
  topEventTypes    Json
  deviceBreakdown  Json
  browserBreakdown Json
  osBreakdown      Json

  @@map("tracking_daily_stats")
}

// ─── UserText tokenization models ────────────────────────────────────────────
// Mirror TextProcessingVersion / TextToken / TextVocabulary / TokenAnalysis
// scoped to UserText (private — never stored in main library).

model UserTextProcessingVersion {
  id               String            @id @default(uuid())
  userTextId       String
  userId           String
  version          Int
  status           ProcessingStatus  @default(IDLE)
  progress         Int               @default(0)
  errorMessage     String?
  isCurrent        Boolean           @default(false)
  trigger          ProcessingTrigger @default(MANUAL)
  useNormalization Boolean           @default(true)
  useMorphAnalysis Boolean           @default(false)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  userText   UserText             @relation("UserTextVersions", fields: [userTextId], references: [id], onDelete: Cascade)
  user       User                 @relation("UserOwnedTextVersions", fields: [userId], references: [id])
  tokens     UserTextToken[]
  vocabulary UserTextVocabulary[]

  @@index([userTextId])
  @@index([userTextId, isCurrent])
  @@map("user_text_processing_version")
}

model UserTextToken {
  id          String      @id @default(cuid())
  versionId   String
  pageIndex   Int
  position    Int
  original    String
  normalized  String
  startOffset Int?
  endOffset   Int?
  status      TokenStatus @default(ANALYZED)
  vocabId     String?

  version  UserTextProcessingVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)
  vocab    UserTextVocabulary?       @relation(fields: [vocabId], references: [id])
  analyses UserTextTokenAnalysis[]

  @@index([versionId])
  @@index([versionId, pageIndex])
  @@map("user_text_token")
}

model UserTextVocabulary {
  id          String  @id @default(cuid())
  versionId   String
  normalized  String
  lemmaId     String?
  translation String?

  version UserTextProcessingVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)
  lemma   Lemma?                    @relation("UserTextVocabLemma", fields: [lemmaId], references: [id])
  tokens  UserTextToken[]

  @@unique([versionId, normalized])
  @@index([versionId])
  @@map("user_text_vocabulary")
}

model UserTextTokenAnalysis {
  id          String         @id @default(cuid())
  tokenId     String
  lemmaId     String?
  source      AnalysisSource @default(ADMIN)
  probability Float?
  isPrimary   Boolean        @default(false)

  token UserTextToken @relation(fields: [tokenId], references: [id], onDelete: Cascade)
  lemma Lemma?        @relation("UserTextTokenLemma", fields: [lemmaId], references: [id])

  @@index([tokenId])
  @@map("user_text_token_analysis")
}

// Private text library: texts added by a user for personal reading only.
// Visibility: owner only. No moderation. Not published to the library.
// To publish, user copies fields into a TextSubmission (separate row, no FK back here).
model UserText {
  id        String       @id @default(uuid())
  userId    String
  title     String
  language  Language     @default(CHE)
  author    String?
  sourceUrl String?
  type      UserTextType @default(EXTERNAL)
  content   Json
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  user               User                        @relation("UserOwnedTexts", fields: [userId], references: [id], onDelete: Cascade)
  processingVersions UserTextProcessingVersion[] @relation("UserTextVersions")
  scriptVersions     UserTextScriptVersion[]

  @@index([userId])
  @@index([userId, type])
  @@map("user_text")
}

enum UserTextType {
  ORIGINAL
  EXTERNAL
}

enum ChScript {
  LATIN
  ARABIC
}

model TextScriptVersion {
  id           String           @id @default(cuid())
  textId       String
  script       ChScript
  status       ProcessingStatus @default(IDLE)
  errorMessage String?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  text         Text             @relation(fields: [textId], references: [id], onDelete: Cascade)
  pages        TextScriptPage[]

  @@unique([textId, script])
  @@map("text_script_version")
}

model TextScriptPage {
  id          String            @id @default(cuid())
  versionId   String
  pageNumber  Int
  contentRich Json
  version     TextScriptVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)

  @@unique([versionId, pageNumber])
  @@map("text_script_page")
}

model UserTextScriptVersion {
  id           String                @id @default(cuid())
  userTextId   String
  script       ChScript
  status       ProcessingStatus      @default(IDLE)
  errorMessage String?
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt
  userText     UserText              @relation(fields: [userTextId], references: [id], onDelete: Cascade)
  pages        UserTextScriptPage[]

  @@unique([userTextId, script])
  @@map("user_text_script_version")
}

model UserTextScriptPage {
  id          String                @id @default(cuid())
  versionId   String
  pageNumber  Int
  contentRich Json
  version     UserTextScriptVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)

  @@unique([versionId, pageNumber])
  @@map("user_text_script_page")
}

