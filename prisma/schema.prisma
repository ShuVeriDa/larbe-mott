// ─── Heritage ────────────────────────────────────────────────────────────────

enum VerificationStatus {
  PENDING
  APPROVED
  REJECTED
}

model Nation {
  id           String         @id @default(uuid())
  slug         String         @unique
  name         Json
  tukhumy      Tukhum[]
  taips        Taip[]
  userHeritages UserHeritage[]

  @@map("nation")
}

model Tukhum {
  id            String         @id @default(uuid())
  slug          String         @unique
  name          Json
  nationId      String
  nation        Nation         @relation(fields: [nationId], references: [id], onDelete: Cascade)
  taips         Taip[]
  userHeritages UserHeritage[]

  @@index([nationId])
  @@map("tukhum")
}

model Taip {
  id            String             @id @default(uuid())
  slug          String             @unique
  name          Json
  nekyi         String[]
  nationId      String
  nation        Nation             @relation(fields: [nationId], references: [id], onDelete: Cascade)
  tukhumId      String?
  tukhum        Tukhum?            @relation(fields: [tukhumId], references: [id], onDelete: SetNull)
  garas         Gara[]
  userHeritage  UserHeritage[]
  status        VerificationStatus @default(APPROVED)
  submittedById String?

  @@index([nationId])
  @@index([tukhumId])
  @@index([status])
  @@map("taip")
}

model Gara {
  id            String             @id @default(uuid())
  slug          String             @unique
  name          Json
  nekyi         String[]
  taipId        String
  taip          Taip               @relation(fields: [taipId], references: [id], onDelete: Cascade)
  userHeritage  UserHeritage[]
  status        VerificationStatus @default(APPROVED)
  submittedById String?

  @@index([taipId])
  @@index([status])
  @@map("gara")
}

model UserHeritage {
  id             String              @id @default(uuid())
  userId         String              @unique
  user           User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Nation
  nationId       String?
  nation         Nation?             @relation(fields: [nationId], references: [id], onDelete: SetNull)

  // Chechen path
  tukhumId       String?
  tukhum         Tukhum?             @relation(fields: [tukhumId], references: [id], onDelete: SetNull)
  hasTukhum      Boolean?
  taipId         String?
  taip           Taip?               @relation(fields: [taipId], references: [id], onDelete: SetNull)
  taipCustom     String?
  taipStatus     VerificationStatus?
  garaId         String?
  gara           Gara?               @relation(fields: [garaId], references: [id], onDelete: SetNull)
  garaCustom     String?
  garaStatus     VerificationStatus?
  nekyi          String?

  // Other nation
  otherNationName String?

  // Location
  countryId        String?
  country          GeoCountry?    @relation(fields: [countryId], references: [id], onDelete: SetNull)
  regionId         String?
  region           GeoRegion?     @relation(fields: [regionId], references: [id], onDelete: SetNull)
  districtId       String?
  district         GeoDistrict?   @relation(fields: [districtId], references: [id], onDelete: SetNull)
  settlementId     String?
  settlement       GeoSettlement? @relation(fields: [settlementId], references: [id], onDelete: SetNull)
  settlementCustom String?
  ancestralVillage String?

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([nationId])
  @@index([tukhumId])
  @@index([taipId])
  @@index([garaId])
  @@index([countryId])
  @@index([regionId])
  @@index([districtId])
  @@index([settlementId])
  @@map("user_heritage")
}

model GeoCountry {
  id           String       @id @default(uuid())
  code         String       @unique
  name         Json
  userHeritages UserHeritage[]
  regions      GeoRegion[]

  @@map("geo_country")
}

model GeoRegion {
  id           String        @id @default(uuid())
  countryId    String
  country      GeoCountry    @relation(fields: [countryId], references: [id], onDelete: Cascade)
  name         Json
  districts    GeoDistrict[]
  userHeritages UserHeritage[]

  @@index([countryId])
  @@map("geo_region")
}

model GeoDistrict {
  id           String          @id @default(uuid())
  regionId     String
  region       GeoRegion       @relation(fields: [regionId], references: [id], onDelete: Cascade)
  name         Json
  settlements  GeoSettlement[]
  userHeritages UserHeritage[]

  @@index([regionId])
  @@map("geo_district")
}

model GeoSettlement {
  id           String        @id @default(uuid())
  districtId   String
  district     GeoDistrict   @relation(fields: [districtId], references: [id], onDelete: Cascade)
  name         Json
  type         GeoSettlementType
  userHeritages UserHeritage[]

  @@index([districtId])
  @@map("geo_settlement")
}

enum GeoSettlementType {
  city
  town
  village
}

model UserPrivacySettings {
  id           String   @id @default(uuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  showPhone    Boolean  @default(false)
  showAge      Boolean  @default(false)
  showHeritage Boolean  @default(true)
  showLocation Boolean  @default(true)
  showActivity Boolean  @default(true)
  showJoinDate Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("user_privacy_settings")
}
