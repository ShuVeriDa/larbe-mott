  deckMaxSize          Int       @default(90)
  dailyNumberedDecks   Int       @default(1)
  user                 User      @relation("UserDeckState", fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_deck_state")
}

model UserDeckLog {
  id        String   @id @default(cuid())
  userId    String
  lemmaId   String
  deckType  DeckType
  result    String
  createdAt DateTime @default(now())
  lemma     Lemma    @relation("LemmaDeckLogs", fields: [lemmaId], references: [id], onDelete: Cascade)
  user      User     @relation("UserDeckLogs", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId])
