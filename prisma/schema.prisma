generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                       String                       @id @default(uuid())
  email                    String                       @unique
  password                 String?
  username                 String                       @unique
  name                     String
  surname                  String
  hashedRefreshToken       String?
  phone                    String?
  avatar                   String?
  avatarThumb              String?
  avatarMedium             String?
  status                   UserStatus                   @default(ACTIVE)
  language                 Language?                    @default(CHE)
  level                    Level?                       @default(A)
  lastActiveAt             DateTime?
  trialEndsAt              DateTime?
  signupAt                 DateTime                     @default(now())
  createdAt                DateTime                     @default(now())
  updatedAt                DateTime                     @updatedAt
  deletedAt                DateTime?
  geminiApiKeyEncrypted    String?
  geminiModel              String?                      @default("gemini-3.1-flash-lite")
  couponRedemptions        CouponRedemption[]
  dictionaryEntries        DictionaryEntry[]            @relation("DictionaryEntryCreator")
  emailChangeTokens        EmailChangeToken[]
  createdFeatureFlags      FeatureFlag[]                @relation("FeatureFlagCreatedBy")
  updatedFeatureFlags      FeatureFlag[]                @relation("FeatureFlagUpdatedBy")
  featureFlagHistoryEvents FeatureFlagHistory[]         @relation("FeatureFlagHistoryActor")
  feedbackReactions        FeedbackReaction[]           @relation("UserFeedbackReactions")
  delegatedFeedbackThreads FeedbackThread[]             @relation("FeedbackThreadAssignedBy")
  assignedFeedbackThreads  FeedbackThread[]             @relation("FeedbackThreadAssignee")
  feedbackThreads          FeedbackThread[]             @relation("UserFeedbackThreads")
  passwordResetTokens      PasswordResetToken[]
  payments                 Payment[]
  phrasebookSuggestions    PhrasebookSuggestion[]
  subscriptions            Subscription[]
  reviewedSuggestions      Suggestion[]                 @relation("SuggestionReviewer")
  authoredSuggestions      Suggestion[]                 @relation("SuggestionAuthor")
  texts                    Text[]                       @relation("text")
  submittedTexts           Text[]                       @relation("TextSubmittedBy")
  textSubmissions          TextSubmission[]             @relation("TextSubmissionAuthor")
  reviewedTextSubmissions  TextSubmission[]             @relation("TextSubmissionReviewer")
  initiatedVersions        TextProcessingVersion[]      @relation("VersionInitiator")
  tokenizationJobs         TokenizationJob[]            @relation("TokenizationJobInitiator")
  deckCards                UserDeckCard[]               @relation("UserDeckCards")
  deckLogs                 UserDeckLog[]                @relation("UserDeckLogs")
  deckState                UserDeckState?               @relation("UserDeckState")
  userDictionaryEntries    UserDictionaryEntry[]        @relation("UserDictionaryEntryUser")
  userDictionaryFolders    UserDictionaryFolder[]       @relation("UserDictionaryFolderUser")
  events                   UserEvent[]                  @relation("UserEventUser")
  setFeatureFlagOverrides  UserFeatureFlag[]            @relation("UserFeatureFlagSetter")
  featureFlags             UserFeatureFlag[]
  goals                    UserGoals?
  notifications            UserNotificationPreferences?
  phrasebookSaves          UserPhrasebookSave[]
  phrasebookProgress       UserPhrasebookProgress[]
  phrasebookReviewLogs     UserPhrasebookReviewLog[]
  preferences              UserPreferences?
  reviewLogs               UserReviewLog[]              @relation("UserReviewLogs")
  roles                    UserRoleAssignment[]
  sessions                 UserSession[]
  bookmarks                UserTextBookmark[]
  textProgress             UserTextProgress[]
  wordProgress             UserWordProgress[]
  wordContexts             WordContext[]
  ownedTexts               UserText[]                   @relation("UserOwnedTexts")
  userTextVersions         UserTextProcessingVersion[]  @relation("UserOwnedTextVersions")
  appNotifications         Notification[]               @relation("UserAppNotifications")
  spellingEntries          SpellingEntry[]              @relation("SpellingEntryCreator")
  announcements            Announcement[]               @relation("AnnouncementCreator")
  accounts                 Account[]                    @relation("UserAccounts")

  @@index([status])
  @@index([language])
  @@index([level])
  @@map("users")

  heritage            UserHeritage?
  privacySettings     UserPrivacySettings?
}

enum AuthProvider {
  GOOGLE
  TELEGRAM
}

model Account {
  id                String       @id @default(uuid())
  userId            String
  provider          AuthProvider
  providerAccountId String
  email             String
  createdAt         DateTime     @default(now())
  user              User         @relation("UserAccounts", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("accounts")
}

model FeatureFlag {
  id             String                   @id @default(uuid())
  key            String                   @unique
  description    String?
  isEnabled      Boolean                  @default(false)
  category       FeatureFlagCategory      @default(FUNCTIONAL)
  environments   FeatureFlagEnvironment[] @default([PROD, STAGE, DEV])
  rolloutPercent Int                      @default(100)
  createdById    String?
  updatedById    String?
  deletedAt      DateTime?
  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt
  createdBy      User?                    @relation("FeatureFlagCreatedBy", fields: [createdById], references: [id])
  updatedBy      User?                    @relation("FeatureFlagUpdatedBy", fields: [updatedById], references: [id])
  historyEvents  FeatureFlagHistory[]
  userOverrides  UserFeatureFlag[]

  @@index([isEnabled])
  @@index([category])
  @@index([deletedAt])
  @@map("feature_flag")
}

model UserFeatureFlag {
  id            String      @id @default(uuid())
  userId        String
  featureFlagId String
  isEnabled     Boolean
  reason        String?
  setById       String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  featureFlag   FeatureFlag @relation(fields: [featureFlagId], references: [id], onDelete: Cascade)
  setBy         User?       @relation("UserFeatureFlagSetter", fields: [setById], references: [id])
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, featureFlagId])
  @@index([featureFlagId])
  @@index([setById])
  @@index([updatedAt])
  @@map("user_feature_flag")
}

model FeatureFlagHistory {
  id        String                      @id @default(uuid())
  flagId    String?
  flagKey   String
  eventType FeatureFlagHistoryEventType
  details   Json?
  actorId   String?
  createdAt DateTime                    @default(now())
  actor     User?                       @relation("FeatureFlagHistoryActor", fields: [actorId], references: [id])
  flag      FeatureFlag?                @relation(fields: [flagId], references: [id])

  @@index([flagId])
  @@index([flagKey])
  @@index([eventType])
  @@index([actorId])
  @@index([createdAt])
  @@map("feature_flag_history")
}

model UserSession {
  id           String    @id @default(uuid())
  userId       String
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime  @default(now())
  lastActiveAt DateTime  @default(now())
  revokedAt    DateTime?
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, revokedAt])
  @@index([createdAt])
  @@index([lastActiveAt])
  @@map("user_session")
}

model PasswordResetToken {
  id               String    @id @default(uuid())
  userId           String
  tokenHash        String    @unique
  expiresAt        DateTime
  usedAt           DateTime?
  requestIp        String?
  requestUserAgent String?
  consumedIp       String?
  createdAt        DateTime  @default(now())
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@index([userId, expiresAt, usedAt])
  @@map("password_reset_tokens")
}

model EmailChangeToken {
  id               String    @id @default(uuid())
  userId           String
  newEmail         String
  tokenHash        String    @unique
  expiresAt        DateTime
  usedAt           DateTime?
  requestIp        String?
  requestUserAgent String?
  consumedIp       String?
  createdAt        DateTime  @default(now())
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@index([userId, expiresAt, usedAt])
  @@map("email_change_tokens")
}

model Plan {
  id                String         @id @default(uuid())
  code              String         @unique
  name              String
  type              PlanType
  description       String?
  priceCents        Int            @default(0)
  currency          String         @default("USD")
  interval          String?
  isActive          Boolean        @default(true)
  groupCode         String?
  trialDays         Int            @default(0)
  displayColor      String?
  iconKey           String?
  highlightFeatures String[]       @default([])
  limits            Json?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  subscriptions     Subscription[]

  @@index([type])
  @@index([isActive])
  @@map("plan")
}

model Subscription {
  id            String              @id @default(uuid())
  userId        String
  planId        String
  status        SubscriptionStatus  @default(TRIALING)
  isLifetime    Boolean             @default(false)
  startDate     DateTime
  endDate       DateTime?
  canceledAt    DateTime?
  provider      PaymentProvider     @default(MANUAL)
  providerSubId String?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  payments      Payment[]
  plan          Plan                @relation(fields: [planId], references: [id])
  user          User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  events        SubscriptionEvent[]

  @@index([userId])
  @@index([planId])
  @@index([status])
  @@map("subscription")
}

model Payment {
  id                String             @id @default(uuid())
  userId            String
  subscriptionId    String?
  provider          PaymentProvider    @default(MANUAL)
  providerPaymentId String?
  status            PaymentStatus      @default(PENDING)
  amountCents       Int
  currency          String             @default("USD")
  refundedCents     Int                @default(0)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  couponRedemptions CouponRedemption[]
  subscription      Subscription?      @relation(fields: [subscriptionId], references: [id])
  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([subscriptionId])
  @@index([status])
  @@map("payment")
}

model Coupon {
  id              String             @id @default(uuid())
  code            String             @unique
  name            String?
  type            CouponType
  amount          Int
  maxRedemptions  Int?
  redeemedCount   Int                @default(0)
  validFrom       DateTime?
  validUntil      DateTime?
  applicablePlans String[]
  maxPerUser      Int?
  newUsersOnly    Boolean            @default(false)
  isStackable     Boolean            @default(false)
  isActive        Boolean            @default(true)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  redemptions     CouponRedemption[]

  @@index([isActive])
  @@map("coupon")
}

model CouponRedemption {
  id         String   @id @default(uuid())
  couponId   String
  userId     String
  paymentId  String?
  redeemedAt DateTime @default(now())
  coupon     Coupon   @relation(fields: [couponId], references: [id], onDelete: Cascade)
  payment    Payment? @relation(fields: [paymentId], references: [id])
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([couponId, userId])
  @@index([couponId])
  @@index([userId])
  @@map("coupon_redemption")
}

model SubscriptionEvent {
  id             String                @id @default(uuid())
  subscriptionId String
  type           SubscriptionEventType
  metadata       Json?
  createdAt      DateTime              @default(now())
  subscription   Subscription          @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([subscriptionId])
  @@index([createdAt])
  @@map("subscription_event")
}

model Role {
  id          String               @id @default(uuid())
  name        RoleName             @unique
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  permissions RolePermission[]
  users       UserRoleAssignment[]

  @@map("role")
}

model Permission {
  id        String           @id @default(uuid())
  code      PermissionCode   @unique
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  roles     RolePermission[]

  @@map("permission")
}

model RolePermission {
  roleId       String
  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permission")
}

model UserRoleAssignment {
  userId     String
  roleId     String
  assignedAt DateTime @default(now())
  assignedBy String?
  role       Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@index([roleId])
  @@map("user_role_assignment")
}

model UserDictionaryFolder {
  id          String                @id @default(uuid())
  userId      String
  name        String
  description String?
  color       String?
  icon        String?
  sortOrder   Int                   @default(0)
  updatedAt   DateTime              @updatedAt
  entries     UserDictionaryEntry[] @relation("UserDictionaryEntryFolder")
  user        User                  @relation("UserDictionaryFolderUser", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("user_dictionary_folder")
}

model UserDictionaryEntry {
  id              String                @id @default(uuid())
  word            String
  normalized      String?
  translation     String
  addedAt         DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  learningLevel   WordStatus            @default(NEW)
  cefrLevel       Level?
  repetitionCount Int                   @default(0)
  folderId        String?
  lemmaId         String?
  userId          String
  folder          UserDictionaryFolder? @relation("UserDictionaryEntryFolder", fields: [folderId], references: [id])
  lemma           Lemma?                @relation("UserDictionaryEntryLemma", fields: [lemmaId], references: [id])
  user            User                  @relation("UserDictionaryEntryUser", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, normalized])
  @@index([userId])
  @@index([folderId])
  @@index([learningLevel])
  @@index([lemmaId])
  @@map("user_dictionary_entry")
}

model DictionaryEntry {
  id           String            @id @default(uuid())
  externalId   String?
  rawWord      String            @unique
  rawWordAlt   String?
  rawTranslate String
  notes        String?
  source       DictionarySource?
  createdById  String?
  cachedAt     DateTime          @default(now())
  createdBy    User?             @relation("DictionaryEntryCreator", fields: [createdById], references: [id])
  headwords    Headword[]
  morphForms   MorphForm[]
  senses       Sense[]
  suggestions  Suggestion[]

  @@index([createdById])
  @@map("dictionary_entry")
}

model DictionaryCache {
  id          String   @id @default(cuid())
  normalized  String   @unique
  lemmaId     String?
  translation String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  examples    Json?
  meanings    Json?

  @@index([normalized])
  @@map("dictionary_cache")
}

model Headword {
  id         String          @id @default(uuid())
  entryId    String
  text       String
  normalized String
  order      Int             @default(0)
  isPrimary  Boolean         @default(false)
  lemmaId    String?
  entry      DictionaryEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  lemma      Lemma?          @relation("HeadwordLemma", fields: [lemmaId], references: [id])

  @@index([normalized])
  @@map("headword")
}

model Lemma {
  id                    String                  @id @default(uuid())
  baseForm              String
  normalized            String
  language              Language
  partOfSpeech          String?
  frequency             Int?
  transliteration       String?
  level                 Level?
  audioUrl              String?
  declensionClass       String?
  domain                String?
  doshamId              Int?
  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt
  feedbackReactions     FeedbackReaction[]      @relation("LemmaFeedbackReactions")
  feedbackThreads       FeedbackThread[]        @relation("LemmaFeedbackThreads")
  headwords             Headword[]              @relation("HeadwordLemma")
  morphForms            MorphForm[]
  vocabulary            TextVocabulary[]
  tokenAnalyses         TokenAnalysis[]         @relation("TokenLemma")
  userTextVocabs        UserTextVocabulary[]    @relation("UserTextVocabLemma")
  userTextAnalyses      UserTextTokenAnalysis[] @relation("UserTextTokenLemma")
  deckCards             UserDeckCard[]          @relation("LemmaDeckCards")
  deckLogs              UserDeckLog[]           @relation("LemmaDeckLogs")
  userDictionaryEntries UserDictionaryEntry[]   @relation("UserDictionaryEntryLemma")
  reviewLogs            UserReviewLog[]         @relation("LemmaReviewLogs")
  wordProgress          UserWordProgress[]
  wordContexts          WordContext[]
  relations             WordRelation[]          @relation("WordRelationLemma")
  inverseRelations      WordRelation[]          @relation("WordRelationRelated")

  @@unique([normalized, language])
  @@index([normalized])
  @@index([language, normalized])
  @@index([doshamId])
  @@map("lemma")
}

/// Suffix-stripping rule engine (see MorphologyRuleEngine). Designed for CHE
/// agglutination and only ever populated with real rules for CHE — AR/RU/EN
/// rows exist in the enum but resolve to empty rule sets by design.
/// AR (Arabic as a studied language) uses root-and-pattern morphology and EN
/// is analytical with minimal inflection — neither fits this suffix model;
/// AR/EN words are looked up via AI-translation on the surface form instead
/// (no lemmatization through this engine).
/// Not wired into the automatic text-processing pipeline (TokenizerProcessor)
/// at all — only reachable via admin analysis/CRUD and the on-demand
/// word-lookup path (both of which must pass language explicitly).
model MorphologyRule {
  id          String        @id @default(uuid())
  suffix      String
  add         String?
  pos         String?
  description String?
  isRegex     Boolean       @default(false)
  matchCount  Int           @default(0)
  type        MorphRuleType
  language    Language      @default(CHE)
  priority    Int           @default(0)
  isActive    Boolean       @default(true)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@unique([suffix, type, language])
  @@index([type, isActive, language])
  @@index([isActive, language])
  @@map("morphology_rule")
}

model MorphForm {
  id          String             @id @default(uuid())
  form        String
  normalized  String
  grammarTag  String?
  translation String?
  gramCase    GrammaticalCase?
  gramNumber  GrammaticalNumber?
  lemmaId     String
  entryId     String?
  entry       DictionaryEntry?   @relation(fields: [entryId], references: [id])
  lemma       Lemma              @relation(fields: [lemmaId], references: [id], onDelete: Cascade)

  @@unique([normalized, lemmaId])
  @@index([normalized])
  @@map("morph_form")
}

model WordRelation {
  id             String           @id @default(uuid())
  lemmaId        String
  relatedLemmaId String
  type           WordRelationType
  lemma          Lemma            @relation("WordRelationLemma", fields: [lemmaId], references: [id], onDelete: Cascade)
  related        Lemma            @relation("WordRelationRelated", fields: [relatedLemmaId], references: [id], onDelete: Cascade)

  @@unique([lemmaId, relatedLemmaId, type])
  @@index([lemmaId])
  @@index([relatedLemmaId])
  @@map("word_relation")
}

model Sense {
  id         String          @id @default(uuid())
  entryId    String
  order      Int
  definition String
  notes      String?
  examples   Example[]
  entry      DictionaryEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)

  @@map("sense")
}

model Example {
  id           String  @id @default(uuid())
  senseId      String
  text         String
  translation  String?
  sourceText   String?
  sourceTextId String?
  sense        Sense   @relation(fields: [senseId], references: [id], onDelete: Cascade)
  source       Text?   @relation("ExampleSourceText", fields: [sourceTextId], references: [id])

  @@index([sourceTextId])
  @@map("example")
}

model UnknownWord {
  id          String            @id @default(uuid())
  word        String
  normalized  String            @unique
  seenCount   Int               @default(1)
  status      UnknownWordStatus @default(PENDING)
  resolvedAt  DateTime?
  firstSeen   DateTime          @default(now())
  lastSeen    DateTime          @default(now())
  lastTokenId String?
  lastTextId  String?

  @@map("unknown_word")
}

model UserEvent {
  id        String        @id @default(uuid())
  userId    String
  type      UserEventType
  metadata  Json?
  createdAt DateTime      @default(now())
  user      User          @relation("UserEventUser", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type])
  @@index([userId, createdAt])
  @@index([userId, type, createdAt])
  @@map("user_event")
}

model Tag {
  id        String    @id @default(uuid())
  name      String    @unique
  createdAt DateTime  @default(now())
  texts     TextTag[]

  @@map("tag")
}

model Genre {
  id        String   @id @default(uuid())
  name      String   @unique
  slug      String   @unique
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  texts     Text[]

  @@map("genre")
}

model TextTag {
  textId String
  tagId  String
  tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)
  text   Text   @relation(fields: [textId], references: [id], onDelete: Cascade)

  @@id([textId, tagId])
  @@index([tagId])
  @@map("text_tag")
}

model Text {
  id                 String                  @id @default(uuid())
  title              String
  description        String?
  level              Level?
  language           Language
  author             String?
  source             String?
  imageUrl           String?
  publishedAt        DateTime?
  archivedAt         DateTime?
  processingStatus   ProcessingStatus        @default(IDLE)
  processingProgress Int                     @default(0)
  processingError    String?
  autoTokenizeOnSave Boolean                 @default(true)
  useNormalization   Boolean                 @default(true)
  useMorphAnalysis   Boolean                 @default(false)
  genreId            String?
  createdById        String
  submittedById      String?
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt
  exampleSources     Example[]               @relation("ExampleSourceText")
  feedbackReactions  FeedbackReaction[]      @relation("TextFeedbackReactions")
  feedbackThreads    FeedbackThread[]        @relation("TextFeedbackThreads")
  suggestions        Suggestion[]            @relation("SuggestionText")
  createdBy          User                    @relation("text", fields: [createdById], references: [id], onDelete: Cascade)
  submittedBy        User?                   @relation("TextSubmittedBy", fields: [submittedById], references: [id], onDelete: SetNull)
  genre              Genre?                  @relation(fields: [genreId], references: [id], onDelete: SetNull)
  pages              TextPage[]
  phraseOccurrences  TextPhraseOccurrence[]
  processingVersions TextProcessingVersion[]
  tags               TextTag[]
  tokenizationJobs   TokenizationJob[]
  bookmarks          UserTextBookmark[]
  progress           UserTextProgress[]
  scriptVersions     TextScriptVersion[]
  wordContexts       WordContext[]
  announcements      Announcement[]

  @@index([publishedAt])
  @@map("text")
}

model TextPage {
  id          String      @id @default(cuid())
  textId      String
  pageNumber  Int
  title       String?
  contentRich Json
  contentRaw  String
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  text        Text        @relation(fields: [textId], references: [id], onDelete: Cascade)
  tokens      TextToken[]

  @@index([textId, pageNumber])
  @@map("text_page")
}

model TextProcessingVersion {
  id               String            @id @default(uuid())
  textId           String
  version          Int
  status           ProcessingStatus  @default(RUNNING)
  progress         Int               @default(0)
  errorMessage     String?
  durationMs       Int?
  isCurrent        Boolean           @default(false)
  trigger          ProcessingTrigger @default(MANUAL)
  initiatorId      String?
  label            String?
  useNormalization Boolean           @default(true)
  useMorphAnalysis Boolean           @default(true)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  initiator        User?             @relation("VersionInitiator", fields: [initiatorId], references: [id])
  text             Text              @relation(fields: [textId], references: [id], onDelete: Cascade)
  tokens           TextToken[]
  logs             TextVersionLog[]
  vocabulary       TextVocabulary[]

  @@unique([textId, version])
  @@index([textId, isCurrent])
  @@map("text_processing_version")
}

model TextVersionLog {
  id        String                @id @default(cuid())
  versionId String
  timestamp DateTime              @default(now())
  level     LogLevel
  message   String
  version   TextProcessingVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)

  @@index([versionId])
  @@map("text_version_log")
}

model TextToken {
  id          String                @id @default(cuid())
  versionId   String
  pageId      String?
  position    Int
  original    String
  normalized  String
  /// Смещение в contentRaw страницы (символы), для замены слова в тексте при редактировании токена
  startOffset Int?
  endOffset   Int?
  status      TokenStatus           @default(ANALYZED)
  vocabId     String?
  page        TextPage?             @relation(fields: [pageId], references: [id], onDelete: Cascade)
  version     TextProcessingVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)
  vocabulary  TextVocabulary?       @relation(fields: [vocabId], references: [id])
  analyses    TokenAnalysis[]

  @@index([normalized])
  @@index([versionId, position])
  @@index([pageId])
  @@index([vocabId])
  @@map("text_token")
}

model TextVocabulary {
  id          String                @id @default(cuid())
  versionId   String
  normalized  String
  lemmaId     String?
  translation String?
  createdAt   DateTime              @default(now())
  tokens      TextToken[]
  lemma       Lemma?                @relation(fields: [lemmaId], references: [id])
  version     TextProcessingVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)

  @@unique([versionId, normalized])
  @@index([normalized])
  @@index([versionId])
  @@map("text_vocabulary")
}

model TokenAnalysis {
  id          String         @id @default(cuid())
  tokenId     String
  lemmaId     String?
  source      AnalysisSource
  probability Float?
  isPrimary   Boolean        @default(false)
  lemma       Lemma?         @relation("TokenLemma", fields: [lemmaId], references: [id])
  token       TextToken      @relation(fields: [tokenId], references: [id], onDelete: Cascade)

  @@index([lemmaId])
  @@index([tokenId])
  @@index([tokenId, isPrimary])
  @@map("token_analysis")
}

model TokenizationSettings {
  id                 Int      @id @default(1)
  autoTokenize       Boolean  @default(true)
  normalization      Boolean  @default(true)
  morphAnalysis      Boolean  @default(true)
  onlineDictionaries Boolean  @default(false)
  updatedAt          DateTime @updatedAt

  @@map("tokenization_settings")
}

model TokenizationJob {
  id            String            @id @default(cuid())
  textId        String
  status        JobStatus         @default(PENDING)
  queuePosition Int?
  trigger       ProcessingTrigger @default(MANUAL)
  initiatorId   String?
  createdAt     DateTime          @default(now())
  startedAt     DateTime?
  finishedAt    DateTime?
  error         String?
  initiator     User?             @relation("TokenizationJobInitiator", fields: [initiatorId], references: [id])
  text          Text              @relation(fields: [textId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([textId])
  @@index([status, createdAt])
  @@map("tokenization_job")
}

model UserWordProgress {
  id          String     @id @default(cuid())
  userId      String
  lemmaId     String
  status      WordStatus @default(NEW)
  seenCount   Int        @default(0)
  repetitions Int        @default(0)
  lastSeen    DateTime?
  nextReview  DateTime?
  easeFactor  Float      @default(2.5)
  interval    Int        @default(0)
  lemma       Lemma      @relation(fields: [lemmaId], references: [id], onDelete: Cascade)
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, lemmaId])
  @@index([userId])
  @@index([userId, nextReview])
  @@index([userId, status, nextReview])
  @@index([lemmaId])
  @@map("user_word_progress")
}

model WordContext {
  id      String   @id @default(cuid())
  userId  String
  lemmaId String
  textId  String
  word    String
  snippet String?
  seenAt  DateTime @default(now())
  lemma   Lemma    @relation(fields: [lemmaId], references: [id], onDelete: Cascade)
  text    Text     @relation(fields: [textId], references: [id], onDelete: Cascade)
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, lemmaId, textId])
  @@index([userId, lemmaId])
  @@index([userId, lemmaId, seenAt])
  @@map("word_context")
}

model UserTextProgress {
  id              String    @id @default(uuid())
  userId          String
  textId          String
  progressPercent Float     @default(0)
  lastOpened      DateTime?
  lastPageNumber  Int       @default(1)
  completedAt     DateTime?
  text            Text      @relation(fields: [textId], references: [id], onDelete: Cascade)
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, textId])
  @@index([userId])
  @@index([textId])
  @@index([userId, completedAt])
  @@map("user_text_progress")
}

model UserTextBookmark {
  id        String   @id @default(cuid())
  userId    String
  textId    String
  createdAt DateTime @default(now())
  text      Text     @relation(fields: [textId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, textId])
  @@index([userId])
  @@map("user_text_bookmark")
}

model UserPageBookmark {
  id         String          @id @default(uuid())
  userId     String
  textId     String
  pageNumber Int
  snippet    String
  createdAt  DateTime        @default(now())
  user       UserPreferences @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@unique([userId, textId, pageNumber])
  @@index([userId, textId])
  @@map("user_page_bookmark")
}

model UserDeckCard {
  id               String    @id @default(cuid())
  userId           String
  lemmaId          String
  deckType         DeckType
  deckNumber       Int?
  movedAt          DateTime  @default(now())
  originDeckType   DeckType?
  originDeckNumber Int?
  lemma            Lemma     @relation("LemmaDeckCards", fields: [lemmaId], references: [id], onDelete: Cascade)
  user             User      @relation("UserDeckCards", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, lemmaId])
  @@index([userId, deckType])
  @@index([userId, deckType, movedAt])
  @@map("user_deck_card")
}

model UserDeckState {
  userId              String    @id
  isEnabled           Boolean   @default(true)
  currentNumberedDeck Int       @default(1)
  lastRotatedAt       DateTime?
  dailyWordCount      Int       @default(5)
  deckMaxSize         Int       @default(90)
  dailyNumberedDecks  Int       @default(1)
  user                User      @relation("UserDeckState", fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_deck_state")
}

model UserDeckLog {
  id        String   @id @default(cuid())
  userId    String
  lemmaId   String
  deckType  DeckType
  result    String
  createdAt DateTime @default(now())
  lemma     Lemma    @relation("LemmaDeckLogs", fields: [lemmaId], references: [id], onDelete: Cascade)
  user      User     @relation("UserDeckLogs", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId])
  @@map("user_deck_log")
}

model PhrasebookCategory {
  id          String                 @id @default(uuid())
  emoji       String
  name        String
  sortOrder   Int                    @default(0)
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt
  phrases     PhrasebookPhrase[]
  suggestions PhrasebookSuggestion[]

  @@map("phrasebook_category")
}

model PhrasebookPhrase {
  id              String                    @id @default(uuid())
  categoryId      String
  original        String
  transliteration String?
  translation     String
  translationEn   String?
  translationAr   String?
  translationDe   String?
  translationFr   String?
  translationTr   String?
  lang            Language
  audioUrl        String?
  sortOrder       Int                       @default(0)
  createdAt       DateTime                  @default(now())
  updatedAt       DateTime                  @updatedAt
  category        PhrasebookCategory        @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  examples        PhrasebookPhraseExample[]
  words           PhrasebookPhraseWord[]
  saves           UserPhrasebookSave[]
  progress        UserPhrasebookProgress[]
  reviewLogs      UserPhrasebookReviewLog[]

  @@index([categoryId])
  @@index([lang])
  @@map("phrasebook_phrase")
}

model PhrasebookPhraseWord {
  id          String           @id @default(uuid())
  phraseId    String
  original    String
  translation String
  position    Int              @default(0)
  phrase      PhrasebookPhrase @relation(fields: [phraseId], references: [id], onDelete: Cascade)

  @@index([phraseId])
  @@map("phrasebook_phrase_word")
}

model PhrasebookPhraseExample {
  id               String           @id @default(uuid())
  phraseId         String
  phrase           String
  translation      String
  context          String?
  phrasebookPhrase PhrasebookPhrase @relation(fields: [phraseId], references: [id], onDelete: Cascade)

  @@index([phraseId])
  @@map("phrasebook_phrase_example")
}

model PhrasebookSuggestion {
  id          String              @id @default(uuid())
  userId      String?
  original    String
  translation String
  lang        Language
  context     String?
  categoryId  String?
  createdAt   DateTime            @default(now())
  category    PhrasebookCategory? @relation(fields: [categoryId], references: [id])
  user        User?               @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("phrasebook_suggestion")
}

model UserPhrasebookSave {
  id        String           @id @default(cuid())
  userId    String
  phraseId  String
  createdAt DateTime         @default(now())
  phrase    PhrasebookPhrase @relation(fields: [phraseId], references: [id], onDelete: Cascade)
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, phraseId])
  @@index([userId])
  @@map("user_phrasebook_save")
}

model UserPhrasebookProgress {
  id          String           @id @default(cuid())
  userId      String
  phraseId    String
  status      PhraseStatus     @default(NEW)
  repetitions Int              @default(0)
  lastSeen    DateTime?
  nextReview  DateTime?
  easeFactor  Float            @default(2.5)
  interval    Int              @default(0)
  phrase      PhrasebookPhrase @relation(fields: [phraseId], references: [id], onDelete: Cascade)
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, phraseId])
  @@index([userId])
  @@index([userId, nextReview])
  @@index([userId, status, nextReview])
  @@index([phraseId])
  @@map("user_phrasebook_progress")
}

model UserPhrasebookReviewLog {
  id             String           @id @default(cuid())
  userId         String
  phraseId       String
  quality        Int
  correct        Boolean
  intervalBefore Int?
  intervalAfter  Int?
  createdAt      DateTime         @default(now())
  phrase         PhrasebookPhrase @relation(fields: [phraseId], references: [id], onDelete: Cascade)
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId])
  @@map("user_phrasebook_review_log")
}

model TextPhrase {
  id          String                 @id @default(uuid())
  original    String
  normalized  String
  translation String
  language    Language
  notes       String?
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt
  occurrences TextPhraseOccurrence[]

  @@unique([normalized, language])
  @@index([language])
  @@map("text_phrase")
}

model TextPhraseOccurrence {
  id                 String     @id @default(uuid())
  phraseId           String
  textId             String
  pageNumber         Int
  startTokenPosition Int
  endTokenPosition   Int
  createdAt          DateTime   @default(now())
  phrase             TextPhrase @relation(fields: [phraseId], references: [id], onDelete: Cascade)
  text               Text       @relation(fields: [textId], references: [id], onDelete: Cascade)

  @@unique([phraseId, textId, pageNumber, startTokenPosition])
  @@index([textId, pageNumber])
  @@index([phraseId])
  @@map("text_phrase_occurrence")
}

model FeedbackThread {
  id                String               @id @default(uuid())
  ticketNumber      Int                  @unique @default(autoincrement())
  userId            String
  type              FeedbackType
  status            FeedbackStatus       @default(NEW)
  priority          FeedbackPriority     @default(MEDIUM)
  title             String?
  assigneeAdminId   String?
  assignedByAdminId String?
  assignedAt        DateTime?
  contextType       FeedbackContextType?
  contextWord       String?
  contextSentence   String?
  contextLemmaId    String?
  contextTextId     String?
  contextPosition   Int?
  contextAction     String?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  closedAt          DateTime?
  messages          FeedbackMessage[]
  assignedByAdmin   User?                @relation("FeedbackThreadAssignedBy", fields: [assignedByAdminId], references: [id])
  assigneeAdmin     User?                @relation("FeedbackThreadAssignee", fields: [assigneeAdminId], references: [id])
  lemma             Lemma?               @relation("LemmaFeedbackThreads", fields: [contextLemmaId], references: [id])
  text              Text?                @relation("TextFeedbackThreads", fields: [contextTextId], references: [id])
  user              User                 @relation("UserFeedbackThreads", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([type])
  @@index([priority])
  @@index([assigneeAdminId])
  @@index([createdAt])
  @@index([updatedAt])
  @@map("feedback_thread")
}

model FeedbackMessage {
  id            String              @id @default(uuid())
  threadId      String
  authorType    FeedbackAuthorType
  messageType   FeedbackMessageType @default(PUBLIC_REPLY)
  authorId      String
  body          String
  isReadByUser  Boolean             @default(false)
  isReadByAdmin Boolean             @default(false)
  createdAt     DateTime            @default(now())
  thread        FeedbackThread      @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@index([threadId])
  @@index([threadId, isReadByAdmin])
  @@index([threadId, isReadByUser])
  @@map("feedback_message")
}

model FeedbackReaction {
  id        String       @id @default(uuid())
  userId    String
  type      ReactionType
  lemmaId   String?
  textId    String?
  createdAt DateTime     @default(now())
  lemma     Lemma?       @relation("LemmaFeedbackReactions", fields: [lemmaId], references: [id], onDelete: Cascade)
  text      Text?        @relation("TextFeedbackReactions", fields: [textId], references: [id], onDelete: Cascade)
  user      User         @relation("UserFeedbackReactions", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([lemmaId])
  @@index([textId])
  @@map("feedback_reaction")
}

model UserReviewLog {
  id             String   @id @default(cuid())
  userId         String
  lemmaId        String
  quality        Int
  correct        Boolean
  intervalBefore Int?
  intervalAfter  Int?
  createdAt      DateTime @default(now())
  lemma          Lemma    @relation("LemmaReviewLogs", fields: [lemmaId], references: [id], onDelete: Cascade)
  user           User     @relation("UserReviewLogs", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId])
  @@map("user_review_log")
}

model UserPreferences {
  userId                 String              @id
  theme                  String              @default("LIGHT")
  uiLanguage             String              @default("RU")
  fontSize               Int                 @default(16)
  popupMode              String              @default("POPUP")
  mobileDisplayMode      String              @default("SHEET")
  highlightKnown         Boolean             @default(true)
  showProgress           Boolean             @default(true)
  autoAddOnClick         Boolean             @default(false)
  showGrammar            Boolean             @default(true)
  showExamples           Boolean             @default(true)
  translationLanguage    String              @default("RU")
  showReviewReminder     Boolean             @default(true)
  enableDecks            Boolean             @default(false)
  enableSm2              Boolean             @default(true)
  enablePhrases          Boolean             @default(true)
  readerFontFamily       String              @default("sans")
  readerFontSize         Int                 @default(17)
  readerColumnWidth      String              @default("md")
  readerPagePadding      String              @default("normal")
  readerLineHeight       String              @default("normal")
  readerLetterSpacing    String              @default("normal")
  readerParagraphSpacing String              @default("none")
  readerTheme            String              @default("default")
  readerBgColor          String              @default("")
  readerWordSpacing      String              @default("normal")
  readerArabicFontFamily String              @default("scheherazade")
  readerArabicFontSize   Int                 @default(22)
  pageBookmarks          UserPageBookmark[]
  user                   User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  textHighlights         UserTextHighlight[]
  textNotes              UserTextNote[]

  @@map("user_preferences")
}

model UserTextHighlight {
  id           String          @id @default(uuid())
  userId       String
  textId       String
  pageNumber   Int
  color        String
  startOffset  Int
  endOffset    Int
  selectedText String
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  user         UserPreferences @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@index([userId, textId, pageNumber])
  @@map("user_text_highlight")
}

model UserTextNote {
  id           String          @id @default(uuid())
  userId       String
  textId       String
  pageNumber   Int
  selectedText String?
  body         String
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  user         UserPreferences @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@index([userId, textId, pageNumber])
  @@map("user_text_note")
}

model UserGoals {
  userId         String @id
  dailyWords     Int    @default(10)
  dailyMinutes   Int    @default(15)
  vocabularyGoal Int    @default(800)
  user           User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_goals")
}

model UserNotificationPreferences {
  userId               String  @id
  repeatReminder       Boolean @default(true)
  weeklyReport         Boolean @default(true)
  newTexts             Boolean @default(false)
  supportReplies       Boolean @default(true)
  marketing            Boolean @default(false)
  reminderTime         String  @default("09:00")
  timezone             String  @default("Europe/Moscow")
  // In-app (колокольчик) уведомления
  inAppFeedbackReply   Boolean @default(true)
  inAppSuggestion      Boolean @default(true)
  inAppTextSubmission  Boolean @default(true)
  inAppNewTexts        Boolean @default(true)
  user                 User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_notification_preferences")
}

model AiTranslationCache {
  id              String        @id @default(uuid())
  lemma           String
  contextSentence String?
  cacheType       AiCacheType   @default(WORD_ONLY)
  sourceLanguage  String        @default("che")
  targetLanguage  String        @default("ru")
  translation     String
  russianGloss    String?
  transliteration String?
  partOfSpeech    String?
  baseForm        String?
  nounClass       String?
  example         String?
  source          String        @default("gemini")
  status          AiCacheStatus @default(PENDING)
  requestCount    Int           @default(1)
  thumbsUp        Int           @default(0)
  thumbsDown      Int           @default(0)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  exportedAt      DateTime?

  @@unique([lemma, cacheType, sourceLanguage, targetLanguage])
  @@index([status])
  @@index([requestCount])
  @@index([lemma])
  @@index([targetLanguage])
  @@index([sourceLanguage])
  @@index([exportedAt])
  @@index([status, exportedAt])
  @@index([lemma, targetLanguage])
  @@map("ai_translation_cache")
}

model DictionaryExportRun {
  id           String    @id @default(uuid())
  triggeredBy  String    @default("cron")
  startedAt    DateTime  @default(now())
  finishedAt   DateTime?
  created      Int       @default(0)
  skipped      Int       @default(0)
  errors       Int       @default(0)
  total        Int       @default(0)
  status       String    @default("running")
  errorMessage String?

  @@index([startedAt])
  @@map("dictionary_export_run")
}

/// Юридические/информационные страницы (Privacy, Terms, Contact и т.п.).
/// Хранятся per-language: один документ — одна пара (slug, lang).
/// Публичный эндпоинт отдаёт только опубликованные; админ видит и черновики.
model LegalDocument {
  id          String    @id @default(uuid())
  slug        String
  lang        String
  title       String
  content     String
  version     Int       @default(1)
  isPublished Boolean   @default(false)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([slug, lang])
  @@index([slug, isPublished])
  @@map("legal_document")
}

model Suggestion {
  id            String           @id @default(uuid())
  userId        String
  entryId       String?
  textId        String?
  normalized    String?
  field         String
  oldValue      String?
  newValue      String
  comment       String?
  status        SuggestionStatus @default(PENDING)
  reviewedBy    String?
  reviewedAt    DateTime?
  reviewComment String?
  createdAt     DateTime         @default(now())
  entry         DictionaryEntry? @relation(fields: [entryId], references: [id], onDelete: Cascade)
  text          Text?            @relation("SuggestionText", fields: [textId], references: [id], onDelete: Cascade)
  reviewer      User?            @relation("SuggestionReviewer", fields: [reviewedBy], references: [id])
  user          User             @relation("SuggestionAuthor", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([entryId])
  @@index([textId])
  @@index([status])
  @@map("suggestion")
}

