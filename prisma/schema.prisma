// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

//////////////////////////////////////////////////////
// ENUMS
//////////////////////////////////////////////////////

enum DictionarySource {
  ADMIN
  IMPORT
  ONLINE
  CACHE
}

//////////////////////////////////////////////////////
// ROLES & PERMISSIONS (RBAC)
//////////////////////////////////////////////////////

enum RoleName {
  LEARNER
  SUPPORT
  CONTENT
  LINGUIST
  ADMIN
  SUPERADMIN
}

enum PermissionCode {
  CAN_EDIT_TEXTS
  CAN_EDIT_DICTIONARY
  CAN_EDIT_MORPHOLOGY
  CAN_MANAGE_USERS
  CAN_MANAGE_BILLING
  CAN_VIEW_ANALYTICS
  CAN_VIEW_LOGS
  CAN_MANAGE_FEATURE_FLAGS
}

//////////////////////////////////////////////////////
// BILLING / MONETIZATION
//////////////////////////////////////////////////////

enum PlanType {
  FREE
  BASIC
  PRO
  PREMIUM
  LIFETIME
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  CANCELED
  EXPIRED
}

enum PaymentProvider {
  STRIPE
  PAYPAL
  PADDLE
  LEMONSQUEEZY
  MANUAL
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
}

enum CouponType {
  PERCENT
  FIXED
}

enum Language {
  CHE
  RU
}

enum Level {
  A1
  A2
  B1
  B2
  C1
  C2
}

enum WordStatus {
  NEW
  LEARNING
  KNOWN
}

enum TokenStatus {
  ANALYZED
  AMBIGUOUS
  NOT_FOUND
}

enum AnalysisSource {
  ADMIN
  CACHE
  ONLINE
  MORPHOLOGY
}

enum UserStatus {
  ACTIVE
  BLOCKED
  FROZEN
  DELETED
}

//////////////////////////////////////////////////////
// USER EVENTS (ANALYTICS)
//////////////////////////////////////////////////////

enum UserEventType {
  START_SESSION
  OPEN_TEXT
  CLICK_WORD
  ADD_TO_DICTIONARY
  FAIL_LOOKUP
}

//////////////////////////////////////////////////////
// USERS
//////////////////////////////////////////////////////

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  password      String
  username      String
  name          String
  surname       String
  hashedRefreshToken String? @db.Text
  phone         String?

  wordProgress  UserWordProgress[]
  textProgress  UserTextProgress[]
  dictionaryEntries DictionaryEntry[] @relation("DictionaryEntryCreator")
  userDictionaryEntries UserDictionaryEntry[] @relation("UserDictionaryEntryUser")
  userDictionaryFolders UserDictionaryFolder[] @relation("UserDictionaryFolderUser")
  
  texts Text[] @relation("text")

  events UserEvent[] @relation("UserEventUser")

  status        UserStatus @default(ACTIVE)
  language      Language? @default(CHE)
  level         Level? @default(A1)

  lastActiveAt  DateTime?
  trialEndsAt   DateTime? //пригодится для trial
  signupAt      DateTime @default(now())

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  deletedAt     DateTime?

  roles         UserRoleAssignment[]

  subscriptions Subscription[]
  payments      Payment[]
  couponRedemptions CouponRedemption[]

  @@index([status]) 
  @@index([language])
  @@index([level])
  @@map("users")
}

model Plan {
  id         String   @id @default(uuid())
  code       String   @unique // e.g. "FREE", "PRO_MONTHLY"
  name       String
  type       PlanType

  priceCents Int      @default(0)
  currency   String   @default("USD")
  interval   String?  // "month" | "year" | null (for lifetime/free)
  isActive   Boolean  @default(true)

  limits     Json?

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  subscriptions Subscription[]

  @@index([type])
  @@index([isActive])
  @@map("plan")
}

model Subscription {
  id            String             @id @default(uuid())
  userId        String
  planId        String

  status        SubscriptionStatus @default(TRIALING)
  isLifetime    Boolean            @default(false)

  startDate     DateTime
  endDate       DateTime?
  canceledAt    DateTime?

  provider      PaymentProvider    @default(MANUAL)
  providerSubId String?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user          User @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan          Plan @relation(fields: [planId], references: [id], onDelete: Restrict)
  payments      Payment[]

  @@index([userId])
  @@index([planId])
  @@index([status])
  @@map("subscription")
}

model Payment {
  id                String         @id @default(uuid())
  userId            String
  subscriptionId    String?

  provider          PaymentProvider @default(MANUAL)
  providerPaymentId String?

  status            PaymentStatus   @default(PENDING)
  amountCents       Int
  currency          String          @default("USD")
  refundedCents     Int             @default(0)

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user              User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscription      Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)

  couponRedemptions CouponRedemption[]

  @@index([userId])
  @@index([subscriptionId])
  @@index([status])
  @@map("payment")
}

model Coupon {
  id             String     @id @default(uuid())
  code           String     @unique
  type           CouponType
  amount         Int        // percent OR cents depending on type

  maxRedemptions Int?
  redeemedCount  Int        @default(0)

  validFrom      DateTime?
  validUntil     DateTime?

  isActive       Boolean    @default(true)

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  redemptions    CouponRedemption[]

  @@index([isActive])
  @@map("coupon")
}

model CouponRedemption {
  id        String   @id @default(uuid())
  couponId  String
  userId    String
  paymentId String?

  redeemedAt DateTime @default(now())

  coupon   Coupon @relation(fields: [couponId], references: [id], onDelete: Cascade)
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  payment  Payment? @relation(fields: [paymentId], references: [id], onDelete: SetNull)

  @@index([couponId])
  @@index([userId])
  @@map("coupon_redemption")
}

model Role {
  id        String   @id @default(uuid())
  name      RoleName @unique

  users     UserRoleAssignment[]
  permissions RolePermission[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("role")
}

model Permission {
  id        String          @id @default(uuid())
  code      PermissionCode  @unique

  roles     RolePermission[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("permission")
}

model RolePermission {
  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permission")
}

model UserRoleAssignment {
  userId String
  roleId String

  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  assignedAt DateTime @default(now())
  assignedBy String?

  @@id([userId, roleId])
  @@index([roleId])
  @@map("user_role_assignment")
}

//////////////////////////////////////////////////////
// USER DICTIONARY FOLDER
//////////////////////////////////////////////////////

model UserDictionaryFolder {
  id        String   @id @default(uuid())
  userId    String
  name      String   // название папки
  sortOrder Int      @default(0)
  user     User     @relation("UserDictionaryFolderUser", fields: [userId], references: [id], onDelete: Cascade)
  entries  UserDictionaryEntry[] @relation("UserDictionaryEntryFolder")
  @@index([userId])
  @@map("user_dictionary_folder")
}

//////////////////////////////////////////////////////
// DICTIONARY CACHE (ONLINE)
//////////////////////////////////////////////////////

model UserDictionaryEntry {
  id               String   @id @default(uuid())
  word             String   // как пользователь видит (или normalized)
  normalized       String?  // для дедупликации и поиска
  translation      String
  addedAt          DateTime @default(now())
  learningLevel    WordStatus @default(NEW)  // NEW | LEARNING | KNOWN
  repetitionCount  Int      @default(0)
  folderId         String?
  lemmaId          String?  // опционально: связь с Lemma, если слово из словаря
  
  userId           String
  user             User     @relation("UserDictionaryEntryUser", fields: [userId], references: [id], onDelete: Cascade)
  
  folder           UserDictionaryFolder? @relation("UserDictionaryEntryFolder", fields: [folderId], references: [id], onDelete: SetNull)
  
  lemma            Lemma?   @relation("UserDictionaryEntryLemma", fields: [lemmaId], references: [id], onDelete: SetNull)
  @@unique([userId, normalized])  // одно и то же слово — одна запись на пользователя (при желании)
  @@index([userId])
  @@index([folderId])
  @@index([learningLevel])
  @@map("user_dictionary_entry")
}
//////////////////////////////////////////////////////
// DICTIONARY CACHE (ONLINE)
//////////////////////////////////////////////////////

model DictionaryEntry {
  id            String   @id @default(uuid())

  externalId    String?
  rawWord       String
  rawWordAlt    String?
  rawTranslate  String
  notes         String?

  source        DictionarySource?
  createdById   String?

  cachedAt      DateTime @default(now())
  createdBy     User?    @relation("DictionaryEntryCreator", fields: [createdById], references: [id], onDelete: SetNull)

  headwords     Headword[]
  senses        Sense[]
  morphForms    MorphForm[]

  @@index([rawWord])
  @@index([createdById])
  @@map("dictionary_entry")
}

model DictionaryCache {
  id          String   @id @default(cuid())

  normalized  String   @unique
  lemmaId     String?
  translation String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([normalized])
  @@map("dictionary_cache")
}

//////////////////////////////////////////////////////
// HEADWORDS
//////////////////////////////////////////////////////

model Headword {
  id         String @id @default(uuid())

  entryId    String
  text       String
  normalized String
  order      Int @default(0)

  entry      DictionaryEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)

  lemmaId    String?
  lemma      Lemma? @relation("HeadwordLemma", fields: [lemmaId], references: [id], onDelete: SetNull)

  @@index([normalized])
  @@map("headword")
}

//////////////////////////////////////////////////////
// LEMMA
//////////////////////////////////////////////////////

model Lemma {
  id            String @id @default(uuid())

  baseForm      String
  normalized    String
  language      Language
  partOfSpeech  String?
  frequency     Int?

  headwords     Headword[] @relation("HeadwordLemma")
  userDictionaryEntries UserDictionaryEntry[] @relation("UserDictionaryEntryLemma")
  morphForms    MorphForm[]
  tokenAnalyses TokenAnalysis[] @relation("TokenLemma")
  vocabulary TextVocabulary[]
  wordProgress  UserWordProgress[]

  @@unique([normalized, language])
  @@index([normalized])
  @@index([language, normalized])   // ← добавить
  @@map("lemma")
}

//////////////////////////////////////////////////////
// MORPH FORMS
//////////////////////////////////////////////////////

model MorphForm {
  id          String @id @default(uuid())

  form        String
  normalized  String
  grammarTag  String?

  lemmaId     String
  entryId     String?

  lemma       Lemma @relation(fields: [lemmaId], references: [id], onDelete: Cascade)
  entry       DictionaryEntry? @relation(fields: [entryId], references: [id], onDelete: SetNull)

  @@index([normalized])
  @@unique([normalized, lemmaId])

  @@map("morph_form")
}

//////////////////////////////////////////////////////
// SENSES
//////////////////////////////////////////////////////

model Sense {
  id         String @id @default(uuid())

  entryId    String
  order      Int
  definition String
  notes      String?

  entry      DictionaryEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)

  examples   Example[]
  @@map("sense")
}

model Example {
  id          String @id @default(uuid())

  senseId     String
  text        String
  translation String?

  sense       Sense @relation(fields: [senseId], references: [id], onDelete: Cascade)
  @@map("example")
}

//////////////////////////////////////////////////////
// UNKNOWN WORDS
//////////////////////////////////////////////////////

model UnknownWord {
  id          String   @id @default(uuid())

  word        String
  normalized  String

  seenCount   Int      @default(1)

  firstSeen   DateTime @default(now())
  lastSeen    DateTime @default(now())

  @@unique([normalized])
  @@map("unknown_word")
}

//////////////////////////////////////////////////////
// USER EVENTS
//////////////////////////////////////////////////////

model UserEvent {
  id        String       @id @default(uuid())

  userId    String
  type      UserEventType

  metadata  Json?
  createdAt DateTime     @default(now())

  user      User @relation("UserEventUser", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type])
  @@map("user_event")
}

//////////////////////////////////////////////////////
// TEXTS
//////////////////////////////////////////////////////

model Text {
  id          String   @id @default(uuid())

  title       String
  level       Level?
  language    Language
  author      String
  source      String?

  publishedAt DateTime?

  createdById   String
  createdBy     User @relation("text", fields: [createdById], references: [id], onDelete: Cascade)

  pages         TextPage[]

  processingVersions TextProcessingVersion[]
  progress           UserTextProgress[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([publishedAt])
  @@map("text")
}

model TextPage {
  id        String @id @default(cuid())

  textId    String
  text      Text   @relation(fields: [textId], references: [id], onDelete: Cascade)

  pageNumber Int

  contentRich Json
  contentRaw  String

  tokens    TextToken[]

  createdAt DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([textId, pageNumber])
  @@map("text_page")
}

//////////////////////////////////////////////////////
// TEXT PROCESSING VERSION
//////////////////////////////////////////////////////

model TextProcessingVersion {
  id        String   @id @default(uuid())

  textId    String
  version   Int

  createdAt DateTime @default(now())
  updatedAt   DateTime @updatedAt

  text      Text @relation(fields: [textId], references: [id], onDelete: Cascade)
  tokens    TextToken[]
  vocabulary TextVocabulary[]

  @@unique([textId, version])
  @@map("text_processing_version")
}

//////////////////////////////////////////////////////
// TOKENS
//////////////////////////////////////////////////////

model TextToken {
  id            String      @id @default(cuid())

  versionId     String
  pageId        String?   // опционально для обратной совместимости; при токенизации всегда задаётся
  position      Int

  original      String
  normalized    String

  /// Смещение в contentRaw страницы (символы), для замены слова в тексте при редактировании токена
  startOffset   Int?
  endOffset     Int?

  status        TokenStatus @default(ANALYZED)

  vocabId       String?
  vocabulary    TextVocabulary? @relation(fields: [vocabId], references: [id], onDelete: SetNull)

  version       TextProcessingVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)
  page          TextPage?  @relation(fields: [pageId], references: [id], onDelete: Cascade)
  analyses      TokenAnalysis[]

  @@index([normalized])
  @@index([versionId, position])
  @@index([pageId])
  @@index([vocabId])
  @@map("text_token")
}

//////////////////////////////////////////////////////
// TEXT_VOCABULARY
//////////////////////////////////////////////////////

model TextVocabulary {
  id          String   @id @default(cuid())

  versionId   String
  normalized  String

  lemmaId     String?
  translation String?

  createdAt   DateTime @default(now())

  version     TextProcessingVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)
  lemma       Lemma? @relation(fields: [lemmaId], references: [id], onDelete: SetNull)

  tokens      TextToken[]

  @@unique([versionId, normalized])
  @@index([normalized])
  @@index([versionId])  
  @@map("text_vocabulary")
}

//////////////////////////////////////////////////////
// TOKEN ANALYSIS
//////////////////////////////////////////////////////

model TokenAnalysis {
  id          String  @id @default(cuid())

  tokenId     String
  lemmaId     String?

  source      AnalysisSource

  probability Float?
  isPrimary   Boolean @default(false)

  token       TextToken @relation(fields: [tokenId], references: [id], onDelete: Cascade)
  lemma       Lemma? @relation("TokenLemma", fields: [lemmaId], references: [id], onDelete: SetNull)

  @@index([lemmaId])
  @@index([tokenId])
  @@map("token_analysis")
}

//////////////////////////////////////////////////////
// USER WORD PROGRESS
//////////////////////////////////////////////////////

model UserWordProgress {
  id          String     @id @default(cuid())

  userId      String
  lemmaId     String

  status      WordStatus @default(NEW)

  seenCount   Int        @default(0)
  repetitions Int        @default(0)

  lastSeen    DateTime?
  nextReview  DateTime?

  easeFactor  Float?
  interval    Int?

  user        User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  lemma       Lemma @relation(fields: [lemmaId], references: [id], onDelete: Cascade)

  @@unique([userId, lemmaId])
  @@index([userId])
  @@index([lemmaId])
  @@map("user_word_progress")
}

//////////////////////////////////////////////////////
// USER TEXT PROGRESS
//////////////////////////////////////////////////////

model UserTextProgress {
  id              String   @id @default(uuid())

  userId          String
  textId          String

  progressPercent Float    @default(0)
  lastOpened      DateTime?

  user            User @relation(fields: [userId], references: [id], onDelete: Cascade)
  text            Text @relation(fields: [textId], references: [id], onDelete: Cascade)

  @@unique([userId, textId])
  @@index([userId])
  @@index([textId])
  @@map("user_text_progress")
}