// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

//////////////////////////////////////////////////////
// ENUMS
//////////////////////////////////////////////////////

enum UserRole {
  USER
  ADMIN
}

enum Language {
  CHE
  RU
}

enum Level {
  A1
  A2
  B1
  B2
  C1
  C2
}

enum WordStatus {
  NEW
  LEARNING
  KNOWN
}

enum TokenStatus {
  ANALYZED
  AMBIGUOUS
  NOT_FOUND
}

//////////////////////////////////////////////////////
// USERS
//////////////////////////////////////////////////////

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  password      String
  username      String
  name          String
  surname       String
  hashedRefreshToken String? @db.Text
  role          UserRole @default(USER)
  phone         String?

  wordProgress  UserWordProgress[]
  textProgress  UserTextProgress[]
  adminDictionaryEntries AdminDictionaryEntry[] @relation("AdminDictionaryCreator")
  texts Text[] @relation("text")

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("users")
}

//////////////////////////////////////////////////////
// ADMIN DICTIONARY (дополнение к онлайн словарю)
//////////////////////////////////////////////////////

model AdminDictionaryEntry {
  id            String   @id @default(uuid())

  word          String
  normalized    String
  translation   String
  notes         String?

  createdById   String
  createdBy     User @relation("AdminDictionaryCreator", fields: [createdById], references: [id])

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  headwords     AdminHeadword[]
  morphForms    AdminMorphForm[]

  @@index([normalized])
  @@map("admin_dictionary_entry")
}

//////////////////////////////////////////////////////
// ADMIN HEADWORDS
//////////////////////////////////////////////////////

model AdminHeadword {
  id         String @id @default(uuid())

  entryId    String
  text       String
  normalized String
  order      Int @default(0)

  entry      AdminDictionaryEntry @relation(fields: [entryId], references: [id])

  lemmaId    String?
  lemma      Lemma? @relation("AdminHeadwordLemma", fields: [lemmaId], references: [id])

  @@index([normalized])
  @@map("admin_headword")
}

//////////////////////////////////////////////////////
// ADMIN MORPH FORMS
//////////////////////////////////////////////////////

model AdminMorphForm {
  id          String @id @default(uuid())

  form        String
  normalized  String
  grammarTag  String?

  lemmaId     String
  entryId     String

  lemma       Lemma @relation("AdminMorphLemma", fields: [lemmaId], references: [id])
  entry       AdminDictionaryEntry @relation(fields: [entryId], references: [id])

  @@index([normalized])
  @@map("admin_morph_form")
}

//////////////////////////////////////////////////////
// DICTIONARY CACHE (ONLINE)
//////////////////////////////////////////////////////

model DictionaryEntry {
  id            String   @id @default(uuid())

  externalId    String?
  rawWord       String
  rawWordAlt    String?
  rawTranslate  String

  source        String?

  cachedAt      DateTime @default(now())

  headwords     Headword[]
  senses        Sense[]
  morphForms    MorphForm[]

  @@index([rawWord])
  @@map("dictionary_entry")
}

//////////////////////////////////////////////////////
// HEADWORDS
//////////////////////////////////////////////////////

model Headword {
  id         String @id @default(uuid())

  entryId    String
  text       String
  normalized String
  order      Int @default(0)

  entry      DictionaryEntry @relation(fields: [entryId], references: [id])

  lemmaId    String?
  lemma      Lemma? @relation("HeadwordLemma", fields: [lemmaId], references: [id])

  @@index([normalized])
  @@map("headword")
}

//////////////////////////////////////////////////////
// LEMMA
//////////////////////////////////////////////////////

model Lemma {
  id            String @id @default(uuid())

  baseForm      String
  normalized    String
  language      Language
  partOfSpeech  String?
  frequency     Int?

  headwords     Headword[] @relation("HeadwordLemma")

  morphForms    MorphForm[]
  tokenAnalyses TokenAnalysis[] @relation("TokenLemma")
  wordProgress  UserWordProgress[]

  adminHeadwords AdminHeadword[] @relation("AdminHeadwordLemma")
  adminForms     AdminMorphForm[] @relation("AdminMorphLemma")

  @@unique([normalized, language])
  @@index([normalized])
  @@map("lemma")
}

//////////////////////////////////////////////////////
// MORPH FORMS
//////////////////////////////////////////////////////

model MorphForm {
  id          String @id @default(uuid())

  form        String
  normalized  String
  grammarTag  String?

  lemmaId     String
  entryId     String?

  lemma       Lemma @relation(fields: [lemmaId], references: [id])
  entry       DictionaryEntry? @relation(fields: [entryId], references: [id])

  @@index([normalized])
  @@map("morph_form")
}

//////////////////////////////////////////////////////
// SENSES
//////////////////////////////////////////////////////

model Sense {
  id         String @id @default(uuid())

  entryId    String
  order      Int
  definition String
  notes      String?

  entry      DictionaryEntry @relation(fields: [entryId], references: [id])

  examples   Example[]
  @@map("sense")
}

model Example {
  id          String @id @default(uuid())

  senseId     String
  text        String
  translation String?

  sense       Sense @relation(fields: [senseId], references: [id])
  @@map("example")
}

//////////////////////////////////////////////////////
// UNKNOWN WORDS
//////////////////////////////////////////////////////

model UnknownWord {
  id          String   @id @default(uuid())

  word        String
  normalized  String

  seenCount   Int      @default(1)

  firstSeen   DateTime @default(now())
  lastSeen    DateTime @default(now())

  @@unique([normalized])
  @@map("unknown_word")
}

//////////////////////////////////////////////////////
// TEXTS
//////////////////////////////////////////////////////

model Text {
  id          String   @id @default(uuid())

  title       String
  level       Level?
  language    Language
  author      String
  source      String?

  createdById   String
  createdBy     User @relation("text", fields: [createdById], references: [id])
  
  pages         TextPage[]

  processingVersions TextProcessingVersion[]
  progress           UserTextProgress[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  @@map("text")
}

model TextPage {
  id        String @id @default(cuid())

  textId    String
  text      Text   @relation(fields: [textId], references: [id])

  pageNumber Int

  contentRich Json
  contentRaw  String

  createdAt DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([textId, pageNumber])
  @@map("text_page")
}

//////////////////////////////////////////////////////
// TEXT PROCESSING VERSION
//////////////////////////////////////////////////////

model TextProcessingVersion {
  id        String   @id @default(uuid())

  textId    String
  version   Int

  createdAt DateTime @default(now())
  updatedAt   DateTime @updatedAt

  text      Text @relation(fields: [textId], references: [id])
  tokens    TextToken[]

  @@unique([textId, version])
  @@map("text_processing_version")
}

//////////////////////////////////////////////////////
// TOKENS
//////////////////////////////////////////////////////

model TextToken {
  id            String      @id @default(cuid())

  versionId     String
  position      Int

  original      String
  normalized    String

  status        TokenStatus @default(ANALYZED)

  version       TextProcessingVersion @relation(fields: [versionId], references: [id])
  analyses      TokenAnalysis[]

  @@index([normalized])
  @@index([versionId, position])
  @@index([versionId, normalized])
  @@map("text_token")
}

//////////////////////////////////////////////////////
// TOKEN ANALYSIS
//////////////////////////////////////////////////////

model TokenAnalysis {
  id          String  @id @default(cuid())

  tokenId     String
  lemmaId     String?

  probability Float?
  isPrimary   Boolean @default(false)

  token       TextToken @relation(fields: [tokenId], references: [id])
  lemma       Lemma? @relation("TokenLemma", fields: [lemmaId], references: [id])

  @@index([lemmaId])
  @@index([tokenId])
  @@map("token_analysis")
}

//////////////////////////////////////////////////////
// USER WORD PROGRESS
//////////////////////////////////////////////////////

model UserWordProgress {
  id          String     @id @default(cuid())

  userId      String
  lemmaId     String

  status      WordStatus @default(NEW)

  repetitions Int        @default(0)

  lastSeen    DateTime?
  nextReview  DateTime?

  easeFactor  Float?
  interval    Int?

  user        User  @relation(fields: [userId], references: [id])
  lemma       Lemma @relation(fields: [lemmaId], references: [id])

  @@unique([userId, lemmaId])
  @@map("user_word_progress")
}

//////////////////////////////////////////////////////
// USER TEXT PROGRESS
//////////////////////////////////////////////////////

model UserTextProgress {
  id              String   @id @default(uuid())

  userId          String
  textId          String

  progressPercent Float    @default(0)
  lastOpened      DateTime?

  user            User @relation(fields: [userId], references: [id])
  text            Text @relation(fields: [textId], references: [id])

  @@unique([userId, textId])
  @@map("user_text_progress")
}