  skipped      Int       @default(0)
  errors       Int       @default(0)
  total        Int       @default(0)
  status       String    @default("running")
  errorMessage String?

  @@index([startedAt])
  @@map("dictionary_export_run")
}

/// Юридические/информационные страницы (Privacy, Terms, Contact и т.п.).
/// Хранятся per-language: один документ — одна пара (slug, lang).
/// Публичный эндпоинт отдаёт только опубликованные; админ видит и черновики.
model LegalDocument {
  id          String    @id @default(uuid())
  slug        String
  lang        String
  title       String
  content     String
  version     Int       @default(1)
  isPublished Boolean   @default(false)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([slug, lang])
  @@index([slug, isPublished])
  @@map("legal_document")
}

model Suggestion {
  id            String           @id @default(uuid())
  userId        String
  entryId       String
  normalized    String?
  field         String
  oldValue      String?
  newValue      String
  comment       String?
  status        SuggestionStatus @default(PENDING)
  reviewedBy    String?
  reviewedAt    DateTime?
  reviewComment String?
  createdAt     DateTime         @default(now())
  entry         DictionaryEntry  @relation(fields: [entryId], references: [id], onDelete: Cascade)
  reviewer      User?            @relation("SuggestionReviewer", fields: [reviewedBy], references: [id])
  user          User             @relation("SuggestionAuthor", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([entryId])
  @@index([status])
  @@map("suggestion")
}

